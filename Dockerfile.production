# PRODUCTION DOCKERFILE — Kyndral-365 (Node + npm)
# The project is npm-based (package-lock.json, start = "node dist/index.cjs",
# build = "tsx script/build.ts"). The old Bun-based Dockerfile failed with
# "lockfile had changes, but lockfile is frozen" because `bun install
# --frozen-lockfile` can't read an npm lockfile. Drop this in at the Kyndral
# repo ROOT as Dockerfile.production (replace the existing one).

# Stage 1: build
FROM node:22-slim AS builder
WORKDIR /app
COPY package.json package-lock.json .npmrc ./
RUN npm ci
COPY . .
RUN npm run build

# Stage 2: production runtime
FROM node:22-slim
WORKDIR /app
RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 --ingroup nodejs nodejs
COPY package.json package-lock.json .npmrc ./
# drizzle-kit is a devDependency (dropped by --omit=dev), but the Railway
# preDeployCommand runs `drizzle-kit push`; install it (unsaved) so it's present.
RUN npm ci --omit=dev && npm install --no-save drizzle-kit@^0.31.4 && npm cache clean --force
COPY --from=builder --chown=nodejs:nodejs /app/dist ./dist
COPY --from=builder --chown=nodejs:nodejs /app/server ./server
COPY --from=builder --chown=nodejs:nodejs /app/shared ./shared
# drizzle-kit push reads drizzle.config.ts (which points at ./shared/schema.ts)
# at deploy time, so it must be in the runtime image too.
COPY --from=builder --chown=nodejs:nodejs /app/drizzle.config.ts ./drizzle.config.ts
COPY --chown=nodejs:nodejs .env.example .env
ENV NODE_ENV=production
ENV PORT=5000
EXPOSE 5000
# The app runs as the non-root `nodejs` user but creates runtime dirs under /app
# (uploads, logs) at startup. Pre-create them owned by nodejs AND make /app itself
# writable, so the app's mkdir succeeds — otherwise it crashes on boot with
# "EACCES: permission denied, mkdir '/app/uploads/documents'". Runs as root (before
# USER nodejs below).
RUN mkdir -p /app/uploads/documents /app/logs \
    && chown -R nodejs:nodejs /app/uploads /app/logs \
    && chown nodejs:nodejs /app

HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD node -e 'fetch("http://localhost:5000/health/live").then(r=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))'
USER nodejs
CMD ["node", "dist/index.cjs"]
