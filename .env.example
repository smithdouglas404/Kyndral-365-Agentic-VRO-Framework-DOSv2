# ============================================================================
# NextEra Energy ETO/VRO Platform - Environment Configuration
# ============================================================================

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
PORT=5000
HOST=0.0.0.0
GRACEFUL_SHUTDOWN_TIMEOUT=30000
INTERNAL_API_URL=http://localhost:5000

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# PostgreSQL Connection String
DATABASE_URL=postgresql://postgres:password@localhost:5432/nextera_eto
POSTGRES_PASSWORD=password

# ============================================================================
# NEO4J KNOWLEDGE GRAPH
# ============================================================================

# Neo4j Connection
NEO4J_URI=neo4j://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Neo4j Browser: http://localhost:7474

# ============================================================================
# ANTHROPIC AI (Claude)
# ============================================================================

# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-...

# ============================================================================
# LANGCHAIN / LANGSMITH (Agent Observability)
# ============================================================================

# LangSmith API Key - Get from: https://smith.langchain.com/
LANGCHAIN_API_KEY=ls__...

# LangSmith Project Name
LANGCHAIN_PROJECT=nexus-ppm

# Enable LangSmith Tracing (true for development, false for production to reduce overhead)
LANGCHAIN_TRACING_V2=true

# LangSmith Endpoint (default)
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ============================================================================
# SESSION & SECURITY
# ============================================================================

# Session Secret - Generate a random string for production
# Example: openssl rand -base64 32
SESSION_SECRET=change-this-to-a-random-secret-in-production

# ============================================================================
# NODE ENVIRONMENT
# ============================================================================

NODE_ENV=development
# Options: development, production

# ============================================================================
# PALANTIR FOUNDRY - ONTOLOGY SOURCE OF TRUTH
# ============================================================================
# Palantir Foundry is the central data hub. All external systems sync TO Palantir.
# The application reads FROM Palantir only.

# Palantir AIP Connection
PALANTIR_HOSTNAME=your-instance.palantirfoundry.com
PALANTIR_TOKEN=your-palantir-bearer-token
# Get token from: Palantir Foundry > Settings > Tokens > Generate new token

# Optional: Specify ontology RID (auto-detected if not set)
PALANTIR_ONTOLOGY_RID=ri.ontology.main.ontology.xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Palantir Actions (for write operations) - Optional, auto-discovered if not set
# PALANTIR_ACTION_CREATE_PROJECT=ri.actions..action.create-project
# PALANTIR_ACTION_UPDATE_PROJECT=ri.actions..action.update-project
# PALANTIR_ACTION_UPSERT_TASK=ri.actions..action.upsert-task

# ============================================================================
# EXTERNAL SYSTEM SYNC CONFIGURATION
# ============================================================================
# These systems sync TO Palantir Foundry on a schedule.
# Data flows: External System → Palantir → Application

# ============================================================================
# JIRA INTEGRATION
# ============================================================================
# Syncs Jira issues/epics/stories → Palantir ontology

JIRA_DOMAIN=your-company.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=your-jira-api-token
# Get API token from: https://id.atlassian.com/manage-profile/security/api-tokens

# Sync Configuration
JIRA_SYNC_ENABLED=true
JIRA_SYNC_CRON=0 */4 * * *
# Default: Every 4 hours (0 */4 * * *)

# Optional: Filter by project
JIRA_PROJECT_KEY=PROJ
# Optional: Custom JQL filter
JIRA_SYNC_JQL=project = PROJ AND updated >= -7d

# ============================================================================
# OPENPROJECT INTEGRATION
# ============================================================================
# Syncs OpenProject work packages → Palantir ontology

OPENPROJECT_URL=https://your-openproject-instance.com
OPENPROJECT_API_KEY=your-openproject-api-key
# Get API key from: OpenProject > My Account > Access Tokens

# Sync Configuration
OPENPROJECT_SYNC_ENABLED=true
OPENPROJECT_SYNC_CRON=0 */6 * * *
# Default: Every 6 hours (0 */6 * * *)

# Optional: Filter by project
OPENPROJECT_PROJECT_ID=my-project

# ============================================================================
# MONDAY.COM INTEGRATION
# ============================================================================
# Syncs Monday.com board items → Palantir ontology

MONDAY_API_TOKEN=your-monday-api-token
# Get token from: Monday.com > Avatar > Developers > My Access Tokens

# Sync Configuration
MONDAY_SYNC_ENABLED=true
MONDAY_SYNC_CRON=0 */2 * * *
# Default: Every 2 hours (0 */2 * * *)

# Required: Board ID to sync
MONDAY_BOARD_ID=1234567890

# ============================================================================
# SERVICENOW INTEGRATION (Optional)
# ============================================================================
SERVICENOW_INSTANCE=your-instance.service-now.com
SERVICENOW_USERNAME=your-username
SERVICENOW_PASSWORD=your-password

# ============================================================================
# AZURE DEVOPS INTEGRATION (Optional)
# ============================================================================
AZURE_DEVOPS_ORG=your-organization
AZURE_DEVOPS_API_URL=https://dev.azure.com

# ============================================================================
# OTHER INTEGRATIONS (Optional)
# ============================================================================
ASANA_ACCESS_TOKEN=your-asana-access-token
SMARTSHEET_ACCESS_TOKEN=your-smartsheet-token
PLANVIEW_API_KEY=your-planview-key
RALLY_API_KEY=your-rally-api-key

# ============================================================================
# OBDA (Ontology-Based Data Access)
# ============================================================================

# Ontop OBDA Service (optional - if using separate Ontop service)
ONTOP_ENDPOINT=http://localhost:8080/sparql

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable/disable specific features
ENABLE_AGENT_SIMULATION=false
# ^ IMPORTANT: Keep this FALSE - simulation is replaced by LangChain agents

ENABLE_KNOWLEDGE_GRAPH=true
ENABLE_DOCUMENT_INTELLIGENCE=true
ENABLE_MCP_SYNC=true

# ============================================================================
# AGENT CONFIGURATION
# ============================================================================

# Agent Scan Intervals (in minutes)
FINOPS_AGENT_INTERVAL=30
TMO_AGENT_INTERVAL=20
RISK_AGENT_INTERVAL=60
GOVERNANCE_AGENT_INTERVAL=120
PLANNING_AGENT_INTERVAL=30
OCM_AGENT_INTERVAL=45
INTEGRATED_MGMT_AGENT_INTERVAL=45

# Enable/disable initial scans at startup
RUN_INITIAL_AGENT_SCANS=true

# ============================================================================
# CACHING
# ============================================================================

# OBDA Query Cache TTL (in milliseconds)
OBDA_CACHE_TTL=300000
# Default: 300000 (5 minutes)

# ============================================================================
# LOGGING
# ============================================================================

# Log Level: debug, info, warn, error
LOG_LEVEL=info

# Enable LangSmith detailed logging
LANGCHAIN_VERBOSE=false

# ============================================================================
# PERFORMANCE TUNING
# ============================================================================

# Max concurrent agent executions
MAX_CONCURRENT_AGENTS=3

# Agent execution timeout (in milliseconds)
AGENT_EXECUTION_TIMEOUT=60000
# Default: 60000 (1 minute)

# GraphQL query complexity limit
GRAPHQL_COMPLEXITY_LIMIT=1000

# ============================================================================
# NOTIFICATIONS
# ============================================================================

# WebSocket Configuration
WEBSOCKET_PORT=5000
WEBSOCKET_PATH=/ws

# Email Notifications (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@company.com
SMTP_PASSWORD=your-smtp-password
NOTIFICATION_FROM_EMAIL=nexus-ppm@company.com

# ============================================================================
# BACKUP & MAINTENANCE
# ============================================================================

# Automatic backup schedule (cron format)
BACKUP_SCHEDULE=0 2 * * *
# Default: Daily at 2 AM

# Data retention period (in days)
AUDIT_TRAIL_RETENTION=90
OBDA_CACHE_RETENTION=7

# ============================================================================
# DEVELOPMENT ONLY
# ============================================================================

# Enable GraphiQL Explorer (disable in production)
ENABLE_GRAPHIQL=true

# Enable Ontology Explorer UI (disable in production)
ENABLE_ONTOLOGY_EXPLORER=true

# Seed demo data on startup (disable in production)
SEED_DEMO_DATA=false

# ============================================================================
# NOTES
# ============================================================================

# 1. Copy this file to .env and fill in your actual values
# 2. Never commit .env to version control
# 3. For production, use a secrets management system (e.g., AWS Secrets Manager)
# 4. Rotate API keys and passwords regularly
# 5. Use strong, unique passwords for all services
# 6. Enable HTTPS/TLS in production
# 7. Review and adjust agent intervals based on your data volume

OPENROUTER_API_URL=https://openrouter.ai/api/v1
APP_URL=https://localhost:5000
MEM0_API_URL=http://localhost:5000/api/mem0


# 1. Copy this file:
#    cp .env.example .env

# 2. Set required variables:
#    - DATABASE_URL
#    - ANTHROPIC_API_KEY
#    - LANGCHAIN_API_KEY (optional but recommended)
#    - SESSION_SECRET

# 3. Start services:
#    docker-compose up -d

# 4. Access the application:
#    http://localhost:5000

# 5. Access Neo4j browser:
#    http://localhost:7474

# 6. View LangSmith traces:
#    https://smith.langchain.com/
