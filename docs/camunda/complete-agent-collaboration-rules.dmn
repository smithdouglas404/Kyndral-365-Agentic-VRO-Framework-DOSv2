      </rule>

      <!-- Rule 20: PMO - CMMI Maturity Gap -->
      <rule id="Rule_PMO_2">
        <inputEntry><text>"pmo"</text></inputEntry>
        <inputEntry><text></text></inputEntry>
        <inputEntry><text></text></inputEntry>
        <inputEntry><text></text></inputEntry>
        <inputEntry><text></text></inputEntry>
        <inputEntry><text></text></inputEntry>
        <inputEntry><text></text></inputEntry>
        <inputEntry><text></text></inputEntry>
        <inputEntry><text>"medium"</text></inputEntry>
        <outputEntry><text>true</text></outputEntry>
