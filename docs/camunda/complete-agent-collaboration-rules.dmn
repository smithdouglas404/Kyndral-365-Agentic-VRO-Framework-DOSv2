        <outputEntry><text>"docs://tmo/Kotter_8_Step_Guide.pdf,docs://tmo/Prosci_ADKAR_Model.pdf,docs://tmo/Change_Impact_Assessment.xlsx"</text></outputEntry>
      </rule>

      <!-- ================================================================ -->
      <!-- VRO AGENT RULES (Benefits Realization, ROI, TCO, NPV)          -->
      <!-- ================================================================ -->

      <!-- Rule 13: VRO - Severe Value Leakage -->
      <rule id="Rule_VRO_1">
        <inputEntry><text>"vro"</text></inputEntry>
        <inputEntry><text></text></inputEntry>
        <inputEntry><text></text></inputEntry>
        <inputEntry><text></text></inputEntry>
        <inputEntry><text></text></inputEntry>
        <inputEntry><text>&lt; 50</text></inputEntry>
        <inputEntry><text></text></inputEntry>
        <inputEntry><text>"execution","closing"</text></inputEntry>
        <inputEntry><text>"high","critical"</text></inputEntry>
        <outputEntry><text>true</text></outputEntry>
        <outputEntry><text>"finops,tmo,governance"</text></outputEntry>
        <outputEntry><text>"urgent"</text></outputEntry>
        <outputEntry><text>"escalate:exec,notify:finops,notify:tmo,email:stakeholders,attach_document:value_leakage_analysis"</text></outputEntry>
        <outputEntry><text>"MSP Benefits Realization, PMI Business Case"</text></outputEntry>
        <outputEntry><text>"docs://vro/MSP_Benefits_Realization.pdf,docs://vro/PMI_Business_Case_Guide.pdf,docs://vro/Value_Leakage_Analysis_Template.xlsx"</text></outputEntry>
      </rule>

      <!-- Rule 14: VRO - ROI Below Threshold -->
      <rule id="Rule_VRO_2">
        <inputEntry><text>"vro"</text></inputEntry>
        <inputEntry><text>&lt; 0.90</text></inputEntry>
        <inputEntry><text></text></inputEntry>
        <inputEntry><text></text></inputEntry>
        <inputEntry><text></text></inputEntry>
        <inputEntry><text>&lt; 80</text></inputEntry>
        <inputEntry><text></text></inputEntry>
        <inputEntry><text></text></inputEntry>
        <inputEntry><text>"medium"</text></inputEntry>
        <outputEntry><text>true</text></outputEntry>
        <outputEntry><text>"finops,tmo"</text></outputEntry>
        <outputEntry><text>"high"</text></outputEntry>
        <outputEntry><text>"notify:finops,notify:tmo,attach_document:roi_analysis"</text></outputEntry>
        <outputEntry><text>"TCO Analysis, NPV Calculation"</text></outputEntry>
        <outputEntry><text>"docs://vro/TCO_Analysis_Guide.pdf,docs://vro/NPV_Calculator.xlsx,docs://vro/ROI_Optimization_Strategies.pdf"</text></outputEntry>
      </rule>

      <!-- ================================================================ -->
      <!-- PLANNING AGENT RULES (PMBOK, PRINCE2, Agile, Scrum, Kanban)   -->
      <!-- ================================================================ -->

      <!-- Rule 15: Planning - Critical Path Risk -->
      <rule id="Rule_Planning_1">
        <inputEntry><text>"planning"</text></inputEntry>
        <inputEntry><text></text></inputEntry>
        <inputEntry><text>&lt; 0.80</text></inputEntry>
        <inputEntry><text>&gt;= 7</text></inputEntry>
        <inputEntry><text></text></inputEntry>
        <inputEntry><text></text></inputEntry>
        <inputEntry><text></text></inputEntry>
        <inputEntry><text></text></inputEntry>
        <inputEntry><text>"high"</text></inputEntry>
        <outputEntry><text>true</text></outputEntry>
        <outputEntry><text>"risk,tmo,pmo"</text></outputEntry>
