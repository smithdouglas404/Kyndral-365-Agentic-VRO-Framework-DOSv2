      <!-- ================================================================ -->
      <!-- PMO AGENT RULES (PMI Portfolio Mgmt, OPM3, CMMI)               -->
      <!-- ================================================================ -->

      <!-- Rule 19: PMO - Portfolio Health Critical -->
      <rule id="Rule_PMO_1">
        <inputEntry><text>"pmo"</text></inputEntry>
        <inputEntry><text>&lt; 0.75</text></inputEntry>
        <inputEntry><text>&lt; 0.75</text></inputEntry>
        <inputEntry><text>&gt;= 7</text></inputEntry>
        <inputEntry><text></text></inputEntry>
        <inputEntry><text></text></inputEntry>
        <inputEntry><text></text></inputEntry>
        <inputEntry><text></text></inputEntry>
