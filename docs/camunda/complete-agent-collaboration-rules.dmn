        <outputEntry><text>true</text></outputEntry>
        <outputEntry><text>"governance,finops,tmo,vro"</text></outputEntry>
        <outputEntry><text>"urgent"</text></outputEntry>
        <outputEntry><text>"escalate:exec,notify:governance,notify:finops,notify:tmo,email:board,attach_document:portfolio_health"</text></outputEntry>
