        <outputEntry><text>"notify:risk,notify:tmo,notify:pmo,attach_document:cpm_analysis"</text></outputEntry>
        <outputEntry><text>"PMBOK CPM/PERT, PRINCE2 Product-Based Planning"</text></outputEntry>
        <outputEntry><text>"docs://planning/PMBOK_CPM_PERT_Chapter.pdf,docs://planning/PRINCE2_Product_Based_Planning.pdf,docs://planning/Critical_Path_Analysis_Template.xlsx"</text></outputEntry>
      </rule>

      <!-- Rule 16: Planning - Agile/Scrum Sprint Issues -->
      <rule id="Rule_Planning_2">
        <inputEntry><text>"planning"</text></inputEntry>
        <inputEntry><text></text></inputEntry>
        <inputEntry><text>&lt; 0.85</text></inputEntry>
        <inputEntry><text></text></inputEntry>
        <inputEntry><text></text></inputEntry>
        <inputEntry><text></text></inputEntry>
        <inputEntry><text></text></inputEntry>
        <inputEntry><text>"execution"</text></inputEntry>
        <inputEntry><text>"medium"</text></inputEntry>
        <outputEntry><text>true</text></outputEntry>
        <outputEntry><text>"tmo,pmo"</text></outputEntry>
