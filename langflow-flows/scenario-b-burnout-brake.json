{
  "name": "Scenario B: Burnout Brake",
  "description": "Auto-response when team burnout risk detected (OCM ↔ Planning ↔ TMO) - Gate E",
  "data": {
    "nodes": [
      {
        "id": "input-1",
        "type": "ChatInput",
        "position": { "x": 100, "y": 100 },
        "data": {
          "type": "ChatInput",
          "node": {
            "template": {
              "input_value": {
                "type": "str",
                "required": true,
                "value": "",
                "name": "input_value"
              }
            },
            "description": "Receive trigger from Logic Gate E (Burnout Brake)",
            "base_classes": ["Message"],
            "display_name": "Gate Trigger Input"
          }
        }
      },
      {
        "id": "http-planning-1",
        "type": "CustomComponent",
        "position": { "x": 400, "y": 200 },
        "data": {
          "type": "CustomComponent",
          "node": {
            "template": {
              "url": { "value": "http://localhost:5000/api/agent-actions/planning/invalidate-capacity", "name": "url" },
              "method": { "value": "POST", "name": "method" },
              "headers": { "value": "{\"Content-Type\": \"application/json\"}", "name": "headers" },
              "body": { "value": "{ \"projectId\": \"{{projectId}}\", \"reason\": \"High burnout risk detected (burnoutRiskIdx: {{burnoutRiskIdx}})\" }", "name": "body" }
            },
            "description": "Invalidate Planning capacity - flag load_vs_capacity_ratio as invalid",
            "base_classes": ["Data"],
            "display_name": "Invalidate Capacity"
          }
        }
      },
      {
        "id": "http-tmo-1",
        "type": "CustomComponent",
        "position": { "x": 400, "y": 350 },
        "data": {
          "type": "CustomComponent",
          "node": {
            "template": {
              "url": { "value": "http://localhost:5000/api/agent-actions/tmo/schedule-coaching", "name": "url" },
              "method": { "value": "POST", "name": "method" },
              "headers": { "value": "{\"Content-Type\": \"application/json\"}", "name": "headers" },
              "body": { "value": "{ \"teamId\": \"{{teamId}}\", \"projectId\": \"{{projectId}}\", \"reason\": \"Burnout prevention - risk index above 0.85\" }", "name": "body" }
            },
            "description": "Schedule TMO coaching session with Scrum Master and RTE",
            "base_classes": ["Data"],
            "display_name": "Schedule Coaching"
          }
        }
      },
      {
        "id": "http-servicenow-1",
        "type": "CustomComponent",
        "position": { "x": 400, "y": 500 },
        "data": {
          "type": "CustomComponent",
          "node": {
            "template": {
              "url": { "value": "http://localhost:5000/api/agent-actions/servicenow/create-incident", "name": "url" },
              "method": { "value": "POST", "name": "method" },
              "headers": { "value": "{\"Content-Type\": \"application/json\"}", "name": "headers" },
              "body": { "value": "{ \"shortDescription\": \"Team Burnout Risk - HR Intervention Required\", \"description\": \"Team {{teamId}} burnout risk: {{burnoutRiskIdx}}\", \"priority\": \"2\", \"urgency\": \"2\", \"impact\": \"2\", \"category\": \"HR\", \"agentId\": \"ocm\" }", "name": "body" }
            },
            "description": "Create ServiceNow incident for HR intervention (optional)",
            "base_classes": ["Data"],
            "display_name": "Create ServiceNow Incident"
          }
        }
      },
      {
        "id": "http-slack-1",
        "type": "CustomComponent",
        "position": { "x": 400, "y": 650 },
        "data": {
          "type": "CustomComponent",
          "node": {
            "template": {
              "url": { "value": "http://localhost:5000/api/agent-actions/slack/notify", "name": "url" },
              "method": { "value": "POST", "name": "method" },
              "headers": { "value": "{\"Content-Type\": \"application/json\"}", "name": "headers" },
              "body": { "value": "{ \"channel\": \"#team-health\", \"text\": \"High burnout risk detected on team {{teamId}} - capacity reduced and coaching scheduled\", \"agentId\": \"ocm\" }", "name": "body" }
            },
            "description": "Send Slack notification (optional)",
            "base_classes": ["Data"],
            "display_name": "Send Slack Alert"
          }
        }
      },
      {
        "id": "output-1",
        "type": "ChatOutput",
        "position": { "x": 700, "y": 400 },
        "data": {
          "type": "ChatOutput",
          "node": {
            "template": {
              "input_value": { "value": "Burnout brake scenario completed: Capacity invalidated, coaching scheduled, HR notified", "name": "input_value" }
            },
            "description": "Return success status",
            "base_classes": ["Message"],
            "display_name": "Response"
          }
        }
      }
    ],
    "edges": [
      { "source": "input-1", "target": "http-planning-1" },
      { "source": "http-planning-1", "target": "http-tmo-1" },
      { "source": "http-tmo-1", "target": "http-servicenow-1" },
      { "source": "http-servicenow-1", "target": "http-slack-1" },
      { "source": "http-slack-1", "target": "output-1" }
    ]
  },
  "is_component": false
}
