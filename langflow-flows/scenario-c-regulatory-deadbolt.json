{
  "name": "Scenario C: Regulatory Deadbolt",
  "description": "Auto-block releases when compliance/security risks detected (Risk ↔ Governance ↔ PMO) - Gates A+C",
  "data": {
    "nodes": [
      {
        "id": "input-1",
        "type": "ChatInput",
        "position": { "x": 100, "y": 100 },
        "data": {
          "type": "ChatInput",
          "node": {
            "template": { "input_value": { "type": "str", "required": true, "value": "", "name": "input_value" } },
            "description": "Receive trigger from Logic Gates A (Compliance-Risk Deadbolt) or C (Audit-Ready Barrier)",
            "base_classes": ["Message"],
            "display_name": "Gate Trigger Input"
          }
        }
      },
      {
        "id": "http-governance-1",
        "type": "CustomComponent",
        "position": { "x": 400, "y": 200 },
        "data": {
          "type": "CustomComponent",
          "node": {
            "template": {
              "url": { "value": "http://localhost:5000/api/agent-actions/governance/block-gate", "name": "url" },
              "method": { "value": "POST", "name": "method" },
              "headers": { "value": "{\"Content-Type\": \"application/json\"}", "name": "headers" },
              "body": { "value": "{ \"projectId\": \"{{projectId}}\", \"reason\": \"Legal exposure exceeds $100K or critical vulnerabilities detected\", \"severity\": \"critical\" }", "name": "body" }
            },
            "description": "Block Governance gate - set gate_status to 'Blocked'",
            "base_classes": ["Data"],
            "display_name": "Block Release Gate"
          }
        }
      },
      {
        "id": "http-pmo-1",
        "type": "CustomComponent",
        "position": { "x": 400, "y": 350 },
        "data": {
          "type": "CustomComponent",
          "node": {
            "template": {
              "url": { "value": "http://localhost:5000/api/agent-actions/pmo/set-flow-status", "name": "url" },
              "method": { "value": "POST", "name": "method" },
              "headers": { "value": "{\"Content-Type\": \"application/json\"}", "name": "headers" },
              "body": { "value": "{ \"projectId\": \"{{projectId}}\", \"epicId\": \"{{epicId}}\", \"flowStatus\": \"Analyzing\", \"reason\": \"Compliance gate blocked - moving back from Implementing\" }", "name": "body" }
            },
            "description": "Move PMO epic back to 'Analyzing' status",
            "base_classes": ["Data"],
            "display_name": "Move Epic to Analyzing"
          }
        }
      },
      {
        "id": "http-pmo-2",
        "type": "CustomComponent",
        "position": { "x": 400, "y": 500 },
        "data": {
          "type": "CustomComponent",
          "node": {
            "template": {
              "url": { "value": "http://localhost:5000/api/agent-actions/pmo/create-epic", "name": "url" },
              "method": { "value": "POST", "name": "method" },
              "headers": { "value": "{\"Content-Type\": \"application/json\"}", "name": "headers" },
              "body": { "value": "{ \"title\": \"Compliance Debt Remediation\", \"description\": \"Audit readiness < 90% with deadline approaching\", \"priority\": \"Highest\", \"projectKey\": \"PMO\" }", "name": "body" }
            },
            "description": "Create highest-priority compliance epic (if audit deadline near)",
            "base_classes": ["Data"],
            "display_name": "Create Compliance Epic"
          }
        }
      },
      {
        "id": "http-jira-1",
        "type": "CustomComponent",
        "position": { "x": 400, "y": 650 },
        "data": {
          "type": "CustomComponent",
          "node": {
            "template": {
              "url": { "value": "http://localhost:5000/api/agent-actions/jira/create-issue", "name": "url" },
              "method": { "value": "POST", "name": "method" },
              "headers": { "value": "{\"Content-Type\": \"application/json\"}", "name": "headers" },
              "body": { "value": "{ \"projectKey\": \"PMO\", \"summary\": \"CRITICAL: Compliance Gate Blocked\", \"description\": \"Release blocked due to compliance/security risk\", \"priority\": \"Highest\", \"issuetype\": \"Bug\", \"agentId\": \"governance\" }", "name": "body" }
            },
            "description": "Create P1 Jira ticket (optional)",
            "base_classes": ["Data"],
            "display_name": "Create Jira Ticket"
          }
        }
      },
      {
        "id": "http-slack-1",
        "type": "CustomComponent",
        "position": { "x": 400, "y": 800 },
        "data": {
          "type": "CustomComponent",
          "node": {
            "template": {
              "url": { "value": "http://localhost:5000/api/agent-actions/slack/notify", "name": "url" },
              "method": { "value": "POST", "name": "method" },
              "headers": { "value": "{\"Content-Type\": \"application/json\"}", "name": "headers" },
              "body": { "value": "{ \"channel\": \"#compliance-alerts\", \"text\": \"@channel CRITICAL: Release blocked - compliance gate failure on project {{projectId}}\", \"agentId\": \"governance\" }", "name": "body" }
            },
            "description": "Send critical Slack alert (optional)",
            "base_classes": ["Data"],
            "display_name": "Send Slack Alert"
          }
        }
      },
      {
        "id": "output-1",
        "type": "ChatOutput",
        "position": { "x": 700, "y": 500 },
        "data": {
          "type": "ChatOutput",
          "node": {
            "template": { "input_value": { "value": "Regulatory deadbolt scenario completed: Gate blocked, epic moved to Analyzing, compliance work prioritized", "name": "input_value" } },
            "description": "Return success status",
            "base_classes": ["Message"],
            "display_name": "Response"
          }
        }
      }
    ],
    "edges": [
      { "source": "input-1", "target": "http-governance-1" },
      { "source": "http-governance-1", "target": "http-pmo-1" },
      { "source": "http-pmo-1", "target": "http-pmo-2" },
      { "source": "http-pmo-2", "target": "http-jira-1" },
      { "source": "http-jira-1", "target": "http-slack-1" },
      { "source": "http-slack-1", "target": "output-1" }
    ]
  },
  "is_component": false
}
