{
  "name": "Scenario D: Maturity Governor",
  "description": "Auto-adjust load based on team maturity (TMO ↔ PMO ↔ Planning) - Gate B",
  "data": {
    "nodes": [
      {
        "id": "input-1",
        "type": "ChatInput",
        "position": { "x": 100, "y": 100 },
        "data": {
          "type": "ChatInput",
          "node": {
            "template": { "input_value": { "type": "str", "required": true, "value": "", "name": "input_value" } },
            "description": "Receive trigger from Logic Gate B (Maturity-Speed Governor)",
            "base_classes": ["Message"],
            "display_name": "Gate Trigger Input"
          }
        }
      },
      {
        "id": "http-pmo-1",
        "type": "CustomComponent",
        "position": { "x": 400, "y": 200 },
        "data": {
          "type": "CustomComponent",
          "node": {
            "template": {
              "url": { "value": "http://localhost:5000/api/agent-actions/pmo/set-flow-status", "name": "url" },
              "method": { "value": "POST", "name": "method" },
              "headers": { "value": "{\"Content-Type\": \"application/json\"}", "name": "headers" },
              "body": { "value": "{ \"projectId\": \"{{projectId}}\", \"sprint_load_factor\": \"{{newLoadFactor}}\", \"reason\": \"Load reduced by 20% due to low team competency (score: {{competencyScore}})\" }", "name": "body" }
            },
            "description": "Update PMO load factor - reduce by 20% (multiply by 0.8)",
            "base_classes": ["Data"],
            "display_name": "Reduce Load Factor"
          }
        }
      },
      {
        "id": "http-planning-1",
        "type": "CustomComponent",
        "position": { "x": 400, "y": 350 },
        "data": {
          "type": "CustomComponent",
          "node": {
            "template": {
              "url": { "value": "http://localhost:5000/api/agent-actions/planning/invalidate-capacity", "name": "url" },
              "method": { "value": "POST", "name": "method" },
              "headers": { "value": "{\"Content-Type\": \"application/json\"}", "name": "headers" },
              "body": { "value": "{ \"projectId\": \"{{projectId}}\", \"reason\": \"Capacity recalculation required - team maturity below threshold\" }", "name": "body" }
            },
            "description": "Invalidate Planning capacity - require recalculation for next PI",
            "base_classes": ["Data"],
            "display_name": "Invalidate Capacity"
          }
        }
      },
      {
        "id": "http-tmo-1",
        "type": "CustomComponent",
        "position": { "x": 400, "y": 500 },
        "data": {
          "type": "CustomComponent",
          "node": {
            "template": {
              "url": { "value": "http://localhost:5000/api/agent-actions/tmo/schedule-coaching", "name": "url" },
              "method": { "value": "POST", "name": "method" },
              "headers": { "value": "{\"Content-Type\": \"application/json\"}", "name": "headers" },
              "body": { "value": "{ \"teamId\": \"{{teamId}}\", \"sessionType\": \"SAFe Agile Training\", \"reason\": \"Team competency score below 2.5 - agile maturity improvement needed\" }", "name": "body" }
            },
            "description": "Schedule TMO training - book SAFe and agile coaching sessions",
            "base_classes": ["Data"],
            "display_name": "Schedule Training"
          }
        }
      },
      {
        "id": "http-slack-1",
        "type": "CustomComponent",
        "position": { "x": 400, "y": 650 },
        "data": {
          "type": "CustomComponent",
          "node": {
            "template": {
              "url": { "value": "http://localhost:5000/api/agent-actions/slack/notify", "name": "url" },
              "method": { "value": "POST", "name": "method" },
              "headers": { "value": "{\"Content-Type\": \"application/json\"}", "name": "headers" },
              "body": { "value": "{ \"channel\": \"#scrum-masters\", \"text\": \"Team {{teamId}} load reduced by 20% - SAFe training scheduled to improve maturity\", \"agentId\": \"tmo\" }", "name": "body" }
            },
            "description": "Notify Scrum Master via Slack (optional)",
            "base_classes": ["Data"],
            "display_name": "Send Slack Alert"
          }
        }
      },
      {
        "id": "output-1",
        "type": "ChatOutput",
        "position": { "x": 700, "y": 400 },
        "data": {
          "type": "ChatOutput",
          "node": {
            "template": { "input_value": { "value": "Maturity governor scenario completed: Load reduced, capacity invalidated, training scheduled", "name": "input_value" } },
            "description": "Return success status",
            "base_classes": ["Message"],
            "display_name": "Response"
          }
        }
      }
    ],
    "edges": [
      { "source": "input-1", "target": "http-pmo-1" },
      { "source": "http-pmo-1", "target": "http-planning-1" },
      { "source": "http-planning-1", "target": "http-tmo-1" },
      { "source": "http-tmo-1", "target": "http-slack-1" },
      { "source": "http-slack-1", "target": "output-1" }
    ]
  },
  "is_component": false
}
